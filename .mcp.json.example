{
  "mcpServers": {
    "tars": {
      "type": "http",
      "url": "http://127.0.0.1:8787/mcp"
    },
    "whatsapp": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "ABSOLUTE_PATH_TO/whatsapp-mcp/whatsapp-mcp-server",
        "run",
        "main.py"
      ],
      "env": {
        "WHATSAPP_API_URL": "http://localhost:8910/api"
      }
    },
    "whatsapp-tars": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "ABSOLUTE_PATH_TO/whatsapp-mcp/whatsapp-mcp-server",
        "run",
        "main.py"
      ],
      "env": {
        "WHATSAPP_API_URL": "http://localhost:8911/api",
        "WHATSAPP_DB_PATH": "ABSOLUTE_PATH_TO/whatsapp-mcp/instances/tars/store/messages.db",
        "WHATSMEOW_DB_PATH": "ABSOLUTE_PATH_TO/whatsapp-mcp/instances/tars/store/whatsapp.db",
        "WHATSAPP_BRIDGE_TOKEN": "GENERATE_A_RANDOM_TOKEN"
      }
    },
    "linkedin": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-linkedin@latest"],
      "env": {
        "UV_HTTP_TIMEOUT": "300"
      }
    },
    "fli": {
      "type": "stdio",
      "command": "fli-mcp",
      "args": []
    },
    "macos": {
      "type": "stdio",
      "command": "uvx",
      "args": ["macos-mcp", "serve", "--transport", "stdio"],
      "env": {
        "UV_HTTP_TIMEOUT": "300"
      }
    }
  }
}
