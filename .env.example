# Tars — Second Brain MCP server. Copy to `.env` and adjust. NEVER commit `.env`.

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=tars
POSTGRES_PASSWORD=tars_dev_password_change_me
POSTGRES_DB=tars
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://tars:tars_dev_password_change_me@localhost:5432/tars

# --- Server -----------------------------------------------------------------
# Loopback (trusted, no-OAuth) listener for Claude Code on this Mac. This listener has
# NO authentication and is ALWAYS hard-bound to 127.0.0.1 (it ignores any HOST override)
# so it can never be exposed to the network.
PORT=8787
# Public (OAuth-protected) listener the tunnel forwards to. Leave PUBLIC_BASE_URL unset
# to run loopback-only (dev). In production set it to the tunnel hostname; it is the
# OAuth issuer AND the RFC 8707 resource identifier, so it must match what clients reach.
PUBLIC_PORT=8788
# PUBLIC_HOST=127.0.0.1
# PUBLIC_BASE_URL=https://your-machine.your-tailnet.ts.net
#
# SECURITY: the single-owner OAuth flow auto-approves /authorize and accepts open client
# registration — anyone who can reach the public URL can mint a token and read/write the
# brain. Prefer a tailnet-only tunnel (Tailscale Serve). The public listener REFUSES to
# start unless you acknowledge this by setting TARS_PUBLIC_AUTH_ACK=1. See SECURITY.md.
# TARS_PUBLIC_AUTH_ACK=1

# --- Embeddings (Phase 4) ---------------------------------------------------
# Provider: ollama | openai | null
#   null   = keyword-only retrieval, ZERO external calls (default, most private)
#   ollama = local, on-device embeddings (nothing leaves the machine) — recommended
EMBEDDING_PROVIDER=null
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Hosted alternative (opt-in; observation text is sent to the provider):
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1
# Embed pre-existing observations missing a vector on server boot:
# TARS_BACKFILL_ON_BOOT=1

# --- Markdown mirror (Phase 6) ----------------------------------------------
# Allowed root for the Markdown mirror. Required to enable the memory_export
# `markdownDir` tool option (writes are confined to this directory); also used by the
# `mirror` one-shot. Leave unset to disable tool-driven mirror writes entirely.
# TARS_MIRROR_DIR=/Users/you/tars-mirror

# --- Fact extraction (Phase 7, optional) ------------------------------------
# Local-LLM extraction of entities/observations/relations from free text
# (confirm-before-write). Off by default; requires a pulled Ollama chat model.
# EXTRACTION_ENABLED=1
# OLLAMA_EXTRACTION_MODEL=llama3.2
