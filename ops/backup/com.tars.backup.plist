<?xml version="1.0" encoding="UTF-8"?>
<!-- Daily Postgres dump at 03:30. TEMPLATE: replace /ABSOLUTE/PATH/TO/tars and set the
     env values, then see ops/backup/README.md. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tars.backup</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/ABSOLUTE/PATH/TO/tars/ops/backup/pg_dump.sh</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>TARS_REPO_DIR</key>
    <string>/ABSOLUTE/PATH/TO/tars</string>
    <key>TARS_BACKUP_DIR</key>
    <string>/ABSOLUTE/PATH/TO/tars-backups</string>
  </dict>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>3</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/tmp/tars-backup.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/tars-backup.err.log</string>
</dict>
</plist>
